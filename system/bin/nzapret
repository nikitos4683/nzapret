#!/system/bin/sh
# nzapret — CLI management utility
# Installed to /system/bin/ via Magisk overlay.
# Provides commands for controlling nfqws service, updating lists,
# managing profiles and diagnostics.

MODDIR="/data/adb/modules/nzapret"
LISTS="$MODDIR/lists"
PAYLOADS="$MODDIR/payloads"
BIN="$MODDIR/bin/nfqws"
CHAIN="nzapret_out"
LOGFILE="$MODDIR/nzapret.log"
EVENTLOG="$MODDIR/nzapret-events.log"
UTILS="$MODDIR/utils"
ACTIVE_PROFILE_FILE="$UTILS/profile.current"
PROFILE_DIR="$MODDIR/profiles"
DEFAULT_PROFILE="default"
DEFAULT_LIST_SOURCE="https://raw.githubusercontent.com/bol-van/rulist/refs/heads/main/reestr_hostname.txt"

# Domains always appended after a manual list refresh.
ALWAYS_INCLUDE_DOMAINS="encryptedsni.com adblockplus.org"

# Helpers
ensure_utils_dir() {
    mkdir -p "$UTILS" >/dev/null 2>&1
}

log_event() {
    _etype="$1"; shift
    _ets=$(date '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo "----")
    printf '%s %-8s %s\n' "$_ets" "$_etype" "$*" >> "$EVENTLOG"
}

require_cmd() {
    command -v "$1" >/dev/null 2>&1 || {
        echo "[-] Missing command: $1"
        exit 1
    }
}

# Process management
get_first_pid() {
    pgrep -x "nfqws" 2>/dev/null | head -n 1
}

get_pid_count() {
    pgrep -x "nfqws" 2>/dev/null | wc -l | tr -d '[:space:]'
}

is_running() {
    [ -n "$(get_first_pid)" ]
}

# Version
get_version() {
    if [ -f "$MODDIR/module.prop" ]; then
        grep '^version=' "$MODDIR/module.prop" | cut -d= -f2 | tr -d '\r\n'
    fi
}

# Profiles
get_active_profile() {
    if [ -f "$ACTIVE_PROFILE_FILE" ]; then
        _pname=$(head -n 1 "$ACTIVE_PROFILE_FILE" 2>/dev/null | tr -d '\r\n')
        [ -n "$_pname" ] && {
            echo "$_pname"
            return
        }
    fi
    echo "$DEFAULT_PROFILE"
}

get_profile_config_file() {
    echo "$PROFILE_DIR/$1.conf"
}

profile_exists() {
    [ -f "$(get_profile_config_file "$1")" ]
}

get_profile_label() {
    _pname="$1"
    _plabel="$_pname"
    _pconfig=$(get_profile_config_file "$_pname")

    if [ -f "$_pconfig" ]; then
        _pline=$(grep -m 1 '^# profile:' "$_pconfig" 2>/dev/null)
        if [ -n "$_pline" ]; then
            _plabel=$(printf '%s' "$_pline" | sed 's/^# profile:[[:space:]]*//')
        fi
    fi

    echo "$_plabel"
}

set_active_profile() {
    _pname="$1"
    profile_exists "$_pname" || {
        echo "[-] Unknown profile: $_pname"
        exit 1
    }
    ensure_utils_dir
    printf '%s\n' "$_pname" > "$ACTIVE_PROFILE_FILE"
}

list_profiles() {
    _found=0
    for _pconfig in "$PROFILE_DIR"/*.conf; do
        [ -f "$_pconfig" ] || continue
        _pname=$(basename "$_pconfig" .conf)
        printf '%s\t%s\n' "$_pname" "$(get_profile_label "$_pname")"
        _found=1
    done
    [ "$_found" = "1" ] || echo "(no profiles found)"
}

# Counters with cache
get_list_count() {
    _cache_file="$1"
    _list_file="$2"
    _force="$3"

    # Return cached value unless forced refresh.
    if [ "$_force" != "1" ] && [ -f "$_cache_file" ]; then
        cat "$_cache_file"
        return
    fi

    if [ -f "$_list_file" ]; then
        _count=$(wc -l < "$_list_file" 2>/dev/null || echo 0)
    else
        _count=0
    fi

    echo "$_count" > "$_cache_file" 2>/dev/null
    echo "$_count"
}

refresh_counts() {
    get_list_count "$MODDIR/.list_count" "$LISTS/list-general.txt" 1 >/dev/null
}

# Status printers

print_profile_status() {
    _pname=$(get_active_profile)
    echo "Active profile: $_pname ($(get_profile_label "$_pname"))"
}

# JSON helper
json_escape() {
    printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

print_status_human() {
    _ver=$(get_version)
    _pid=$(get_first_pid)
    _pid_count=$(get_pid_count)
    _rules=$(get_rule_count iptables)
    _rules6=$(get_rule_count ip6tables)
    _lc=$(get_list_count "$MODDIR/.list_count" "$LISTS/list-general.txt")

    [ -n "$_ver" ] && echo "Module version: $_ver"

    if [ -n "$_pid" ]; then
        echo "nfqws: [ON] (PID: $_pid)"
        [ "$_pid_count" -gt 1 ] && echo "warning: multiple nfqws processes detected ($_pid_count)"
    else
        echo "nfqws: [OFF]"
    fi

    echo "iptables rules: $_rules (IPv4), $_rules6 (IPv6)"
    print_profile_status
    echo ""

    if [ -f "$LISTS/list-general.txt" ]; then
        echo "list-general.txt: $_lc domains"
    else
        echo "list-general.txt: MISSING"
    fi
}

print_status_json() {
    _pid=$(get_first_pid)
    _pid_count=$(get_pid_count)
    if [ -n "$_pid" ]; then
        _active=true
    else
        _active=false
    fi

    _ver=$(get_version)
    _rules=$(get_rule_count iptables)
    _rules6=$(get_rule_count ip6tables)
    _lc=$(get_list_count "$MODDIR/.list_count" "$LISTS/list-general.txt")
    _prof_name=$(get_active_profile)
    _prof_label=$(get_profile_label "$_prof_name")

    printf '{"version":"%s","active":%s,"pid":"%s","pid_count":%s,"rules_v4":%s,"rules_v6":%s,"domain_count":%s,"profile":"%s","profile_label":"%s"}\n' \
        "$(json_escape "$_ver")" "$_active" "$(json_escape "$_pid")" "$_pid_count" "$_rules" "$_rules6" "$_lc" "$(json_escape "$_prof_name")" "$(json_escape "$_prof_label")"
}

get_rule_count() {
    _tbl_cmd="$1"
    $_tbl_cmd -t mangle -L "$CHAIN" -n 2>/dev/null | grep -c NFQUEUE
}

# Service control
start_service() {
    sh "$MODDIR/service.sh" manual || return 1
    is_running
}

stop_service() {
    sh "$MODDIR/uninstall.sh" || return 1
    is_running && return 1
    # Verify all chains are fully removed (OUTPUT + FORWARD).
    iptables -t mangle -C OUTPUT -j "$CHAIN" >/dev/null 2>&1 && return 1
    iptables -t mangle -C FORWARD -j "$CHAIN" >/dev/null 2>&1 && return 1
    ip6tables -t mangle -C OUTPUT -j "$CHAIN" >/dev/null 2>&1 && return 1
    ip6tables -t mangle -C FORWARD -j "$CHAIN" >/dev/null 2>&1 && return 1
    return 0
}

# Safe download (uses tmp file + size check + HTTP error protection)
download_to_tmp() {
    _url="$1"
    _dest="$2"
    _label="$3"
    _tmp=$(mktemp 2>/dev/null || echo "/data/local/tmp/$(basename "$_dest").tmp")

    curl -s -f -L -o "$_tmp" "$_url" 2>/dev/null
    if [ -s "$_tmp" ]; then
        mv -f "$_tmp" "$_dest"
        echo "[+] $_label updated"
        return 0
    fi

    rm -f "$_tmp"
    echo "[-] Failed to download $_label"
    return 1
}

update_list_file() {
    if download_to_tmp "$DEFAULT_LIST_SOURCE" "$LISTS/list-general.txt" "list-general.txt"; then
        printf '%s\n' $ALWAYS_INCLUDE_DOMAINS >> "$LISTS/list-general.txt"
        return 0
    fi
    return 1
}

restart_if_running() {
    if is_running; then
        echo "[*] Restarting nfqws to apply changes..."
        exec "$0" restart
    fi
    echo "[*] nzapret is not running. Changes will apply on next start."
    exit 0
}

# Diagnostics
run_diagnose() {
    echo "nzapret diagnostics"
    echo "--------------------"

    for _cmd in iptables ip6tables pgrep tail curl ip; do
        if command -v "$_cmd" >/dev/null 2>&1; then
            echo "[OK] command available: $_cmd"
        else
            echo "[!!] missing command: $_cmd"
        fi
    done

    _active_profile=$(get_active_profile)
    _active_profile_config=$(get_profile_config_file "$_active_profile")

    for _file in \
        "$BIN" \
        "$_active_profile_config" \
        "$LISTS/list-general.txt" \
        "$LISTS/list-google.txt" \
        "$PAYLOADS/quic_initial_www_google_com.bin" \
        "$PAYLOADS/tls_clienthello_www_google_com.bin"; do
        if [ -f "$_file" ]; then
            echo "[OK] file present: $_file"
        else
            echo "[!!] missing file: $_file"
        fi
    done

    _pid=$(get_first_pid)
    if [ -n "$_pid" ]; then
        echo "[OK] nfqws running (PID: $_pid)"
    else
        echo "[!!] nfqws is not running"
    fi

    # Check all jump rules (OUTPUT + FORWARD)
    for _chain in OUTPUT FORWARD; do
        if iptables -t mangle -C "$_chain" -j "$CHAIN" >/dev/null 2>&1; then
            echo "[OK] iptables $_chain jump present"
        else
            echo "[!!] iptables $_chain jump missing"
        fi

        if ip6tables -t mangle -C "$_chain" -j "$CHAIN" >/dev/null 2>&1; then
            echo "[OK] ip6tables $_chain jump present"
        else
            echo "[!!] ip6tables $_chain jump missing"
        fi
    done

    if command -v ip >/dev/null 2>&1; then
        if ip route get 1.1.1.1 >/dev/null 2>&1; then
            echo "[OK] IPv4 route lookup works"
        else
            echo "[!!] IPv4 route lookup failed"
        fi

        if ip -6 addr show scope global 2>/dev/null | grep -q 'inet6 '; then
            if ip -6 route get 2606:4700:4700::1111 >/dev/null 2>&1; then
                echo "[OK] IPv6 route lookup works"
            else
                echo "[!!] IPv6 route lookup failed"
            fi
        else
            echo "[OK] IPv6 not configured on active network"
        fi
    fi

    print_profile_status
}

run_diagnose_json() {
    _checks=""
    _ok=0
    _fail=0
    _sep=""

    for _cmd in iptables ip6tables pgrep tail curl ip; do
        if command -v "$_cmd" >/dev/null 2>&1; then
            _checks="${_checks}${_sep}{\"name\":\"$(json_escape "$_cmd")\",\"status\":\"ok\",\"detail\":\"command available\"}"
            _ok=$((_ok + 1))
        else
            _checks="${_checks}${_sep}{\"name\":\"$(json_escape "$_cmd")\",\"status\":\"fail\",\"detail\":\"command missing\"}"
            _fail=$((_fail + 1))
        fi
        _sep=","
    done

    _active_profile=$(get_active_profile)
    _active_profile_config=$(get_profile_config_file "$_active_profile")

    for _file in \
        "$BIN" \
        "$_active_profile_config" \
        "$LISTS/list-general.txt" \
        "$LISTS/list-google.txt" \
        "$PAYLOADS/quic_initial_www_google_com.bin" \
        "$PAYLOADS/tls_clienthello_www_google_com.bin"; do
        _fname=$(basename "$_file")
        if [ -f "$_file" ]; then
            _checks="${_checks}${_sep}{\"name\":\"$(json_escape "$_fname")\",\"status\":\"ok\",\"detail\":\"file present\"}"
            _ok=$((_ok + 1))
        else
            _checks="${_checks}${_sep}{\"name\":\"$(json_escape "$_fname")\",\"status\":\"fail\",\"detail\":\"file missing\"}"
            _fail=$((_fail + 1))
        fi
        _sep=","
    done

    _pid=$(get_first_pid)
    if [ -n "$_pid" ]; then
        _checks="${_checks}${_sep}{\"name\":\"nfqws process\",\"status\":\"ok\",\"detail\":\"running (pid: $_pid)\"}"
        _ok=$((_ok + 1))
    else
        _checks="${_checks}${_sep}{\"name\":\"nfqws process\",\"status\":\"fail\",\"detail\":\"not running\"}"
        _fail=$((_fail + 1))
    fi
    _sep=","

    for _ct in OUTPUT FORWARD; do
        if iptables -t mangle -C "$_ct" -j "$CHAIN" >/dev/null 2>&1; then
            _checks="${_checks}${_sep}{\"name\":\"iptables $_ct\",\"status\":\"ok\",\"detail\":\"jump present\"}"
            _ok=$((_ok + 1))
        else
            _checks="${_checks}${_sep}{\"name\":\"iptables $_ct\",\"status\":\"fail\",\"detail\":\"jump missing\"}"
            _fail=$((_fail + 1))
        fi
        if ip6tables -t mangle -C "$_ct" -j "$CHAIN" >/dev/null 2>&1; then
            _checks="${_checks}${_sep}{\"name\":\"ip6tables $_ct\",\"status\":\"ok\",\"detail\":\"jump present\"}"
            _ok=$((_ok + 1))
        else
            _checks="${_checks}${_sep}{\"name\":\"ip6tables $_ct\",\"status\":\"fail\",\"detail\":\"jump missing\"}"
            _fail=$((_fail + 1))
        fi
    done

    if command -v ip >/dev/null 2>&1; then
        if ip route get 1.1.1.1 >/dev/null 2>&1; then
            _checks="${_checks}${_sep}{\"name\":\"IPv4 routing\",\"status\":\"ok\",\"detail\":\"route lookup works\"}"
            _ok=$((_ok + 1))
        else
            _checks="${_checks}${_sep}{\"name\":\"IPv4 routing\",\"status\":\"fail\",\"detail\":\"route lookup failed\"}"
            _fail=$((_fail + 1))
        fi
        if ip -6 addr show scope global 2>/dev/null | grep -q 'inet6 '; then
            if ip -6 route get 2606:4700:4700::1111 >/dev/null 2>&1; then
                _checks="${_checks}${_sep}{\"name\":\"IPv6 routing\",\"status\":\"ok\",\"detail\":\"route lookup works\"}"
                _ok=$((_ok + 1))
            else
                _checks="${_checks}${_sep}{\"name\":\"IPv6 routing\",\"status\":\"fail\",\"detail\":\"route lookup failed\"}"
                _fail=$((_fail + 1))
            fi
        else
            _checks="${_checks}${_sep}{\"name\":\"IPv6 routing\",\"status\":\"ok\",\"detail\":\"not configured\"}"
            _ok=$((_ok + 1))
        fi
    fi

    _total=$((_ok + _fail))
    printf '{"checks":[%s],"summary":{"ok":%d,"fail":%d,"total":%d}}\n' \
        "$_checks" "$_ok" "$_fail" "$_total"
}

print_events_text() {
    _tail="${1:-30}"
    if [ -f "$EVENTLOG" ]; then
        tail -n "$_tail" "$EVENTLOG"
    else
        echo "No events recorded yet."
    fi
}

print_events_json() {
    _tail="${1:-30}"
    [ -f "$EVENTLOG" ] || { echo '[]'; return; }
    tail -n "$_tail" "$EVENTLOG" 2>/dev/null | {
        printf '['
        _sep=""
        _found=0
        while read -r _date _clock _type _msg || [ -n "$_date$_clock$_type$_msg" ]; do
            [ -n "$_date$_clock$_type" ] || continue
            printf '%s{"time":"%s %s","type":"%s","message":"%s"}' \
                "$_sep" \
                "$_date" \
                "$_clock" \
                "$_type" \
                "$(json_escape "$_msg")"
            _sep=","
            _found=1
        done
        [ "$_found" = "1" ] || printf ''
        printf ']\n'
    }
}

# Entry point
ensure_utils_dir

[ $# -eq 0 ] && {
    set -- help
}

case "$1" in
    "start")
        if is_running; then
            echo "[!] nfqws is already running. Use 'nzapret restart' instead."
            exit 1
        fi
        echo "[*] Starting nzapret..."
        if start_service; then
            _pid=$(get_first_pid)
            echo "[+] nfqws started successfully (PID: $_pid)"
        else
            echo "[-] Failed to start nfqws. Check 'nzapret log' for details."
            exit 1
        fi
        ;;

    "stop")
        echo "[*] Stopping nzapret..."
        if stop_service; then
            echo "[+] Stopped"
        else
            echo "[-] Failed to stop cleanly. Check 'nzapret log' for details."
            exit 1
        fi
        ;;

    "restart")
        echo "[*] Restarting nzapret..."
        if ! stop_service; then
            echo "[-] Failed to stop current nfqws instance cleanly."
            exit 1
        fi
        if start_service; then
            _pid=$(get_first_pid)
            echo "[+] nfqws restarted successfully (PID: $_pid)"
        else
            echo "[-] Failed to restart nfqws. Check 'nzapret log' for details."
            exit 1
        fi
        ;;

    "update")
        require_cmd curl
        case "$2" in
            ""|"all"|"list")
                echo "[*] Updating list-general.txt..."
                if update_list_file; then
                    _new_count=$(wc -l < "$LISTS/list-general.txt" 2>/dev/null || echo "?")
                    log_event UPDATE "list-general.txt updated ($_new_count domains)"
                    refresh_counts
                    restart_if_running
                else
                    log_event ERROR "list-general.txt update failed"
                    exit 1
                fi
                ;;
            *)
                echo "Usage: nzapret update [list]"
                exit 1
                ;;
        esac
        ;;

    "status")
        case "$2" in
            "--json") print_status_json ;;
            *)        print_status_human ;;
        esac
        ;;

    "log")
        _pid=$(get_first_pid)
        _pid_count=$(get_pid_count)
        if [ -n "$_pid" ] && [ -d "/proc/$_pid" ]; then
            echo "nfqws is running (PID: $_pid)"
            [ "$_pid_count" -gt 1 ] && echo "warning: multiple nfqws processes detected ($_pid_count)"
            echo "Cmdline:"
            cat /proc/$_pid/cmdline 2>/dev/null | tr '\0' ' '
            echo ""
            echo ""
            echo "Open files: $(ls /proc/$_pid/fd 2>/dev/null | wc -l)"
            echo "Memory: $(grep VmRSS /proc/$_pid/status 2>/dev/null)"
        else
            echo "nfqws is not running"
        fi

        echo ""
        echo "Last 50 lines of logs:"
        if [ -f "$LOGFILE" ]; then
            tail -n 50 "$LOGFILE"
        else
            echo "Log file not found."
        fi
        ;;

    "profile")
        case "$2" in
            ""|"status")
                print_profile_status
                ;;
            "list")
                list_profiles
                ;;
            "set")
                [ -n "$3" ] || {
                    echo "Usage: nzapret profile set <name>"
                    exit 1
                }
                set_active_profile "$3"
                log_event PROFILE "changed to $3 ($(get_profile_label "$3"))"
                echo "[+] Active profile set to: $3"
                echo "[*] Restart nzapret to apply changes"
                ;;
            *)
                echo "Usage: nzapret profile [status|list|set <name>]"
                exit 1
                ;;
        esac
        ;;

    "diagnose")
        case "$2" in
            "--json") run_diagnose_json ;;
            *)        run_diagnose ;;
        esac
        ;;

    "events")
        _evt_tail=30
        _evt_json=0
        _evt_clear=0
        shift
        for _arg in "$@"; do
            case "$_arg" in
                "clear"|"--clear") _evt_clear=1 ;;
                --json) _evt_json=1 ;;
                --tail=*) _evt_tail="${_arg#--tail=}" ;;
            esac
        done
        if [ "$_evt_clear" = "1" ]; then
            : > "$EVENTLOG" || {
                echo "[-] Failed to clear event log."
                exit 1
            }
            echo "[+] Event log cleared."
        elif [ "$_evt_json" = "1" ]; then
            print_events_json "$_evt_tail"
        else
            print_events_text "$_evt_tail"
        fi
        ;;

    "help"|"--help"|"-h"|*)
        echo "nzapret Management Utility (Magisk)"
        echo "Usage: nzapret <command> [options]"
        echo ""
        echo "Commands:"
        echo "  start                       - start traffic interception"
        echo "  stop                        - stop interception and clear rules"
        echo "  restart                     - restart nfqws and iptables rules"
        echo "  update [list]               - update routing hostlist"
        echo "  status                      - show nfqws, iptables and list info"
        echo "  status --json               - machine-readable status for WebUI"
        echo "  log                         - show nfqws runtime log"
        echo "  events                      - show event history"
        echo "  events clear                - clear the whole event log file"
        echo "  events --json [--tail=N]    - event history as JSON"
        echo "  profile <subcommand>        - show, list or switch nfqws profiles"
        echo "  diagnose                    - run Android-side diagnostics"
        echo "  diagnose --json             - diagnostics as JSON for WebUI"
        echo "  help                        - show this help message"
        echo ""
        echo "Profile commands: status, list, set <name>"
        ;;
esac
