#!/system/bin/sh
# nzapret — CLI management utility
# Installed to /system/bin/ via Magisk overlay.
# Provides commands for controlling nfqws2 service, updating lists,
# managing profiles and diagnostics.

MODDIR="/data/adb/modules/nzapret"
LISTS="$MODDIR/lists"
USER_LIST_FILE="$LISTS/list-user.txt"
GENERAL_LIST_FILE="$LISTS/list-general.txt"
GOOGLE_LIST_FILE="$LISTS/list-google.txt"
PAYLOADS="$MODDIR/payloads"
LUA_DIR="$MODDIR/lua"
PAYLOAD_QUIC_FILE="$PAYLOADS/quic_initial_www_google_com.bin"
PAYLOAD_TLS_FILE="$PAYLOADS/tls_clienthello_www_google_com.bin"
BIN="$MODDIR/bin/nfqws2"
CHAIN="nzapret_out"
LOGFILE="$MODDIR/nzapret.log"
EVENTLOG="$MODDIR/nzapret-events.log"
PROFILE_DIR="$MODDIR/profiles"
ACTIVE_PROFILE_FILE="$PROFILE_DIR/profile.current"
DEFAULT_PROFILE="default"
PROCESS_NAME="nfqws2"
LIST_COUNT_CACHE="$MODDIR/.list_count"
DIAGNOSE_COMMANDS="iptables ip6tables pgrep tail curl ip"
DEFAULT_LIST_SOURCE="https://raw.githubusercontent.com/bol-van/rulist/refs/heads/main/reestr_hostname.txt"

# Helpers
ensure_runtime_layout() {
    mkdir -p "$PROFILE_DIR" >/dev/null 2>&1
    mkdir -p "$LISTS" >/dev/null 2>&1
    [ -f "$USER_LIST_FILE" ] || : > "$USER_LIST_FILE" 2>/dev/null
}

log_event() {
    _etype="$1"; shift
    _ets=$(date '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo "----")
    printf '%s %-8s %s\n' "$_ets" "$_etype" "$*" >> "$EVENTLOG"
}

has_cmd() {
    command -v "$1" >/dev/null 2>&1
}

require_cmd() {
    has_cmd "$1" || {
        echo "[-] Missing command: $1"
        exit 1
    }
}

json_escape() {
    printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

print_human_check() {
    _status="$1"
    _detail="$2"
    case "$_status" in
        ok)   echo "[OK] $_detail" ;;
        fail) echo "[!!] $_detail" ;;
    esac
}

append_json_check() {
    _name="$1"
    _status="$2"
    _detail="$3"
    _checks="${_checks}${_sep}{\"name\":\"$(json_escape "$_name")\",\"status\":\"$_status\",\"detail\":\"$(json_escape "$_detail")\"}"
    _sep=","
    if [ "$_status" = "ok" ]; then
        _ok=$((_ok + 1))
    else
        _fail=$((_fail + 1))
    fi
}

# Process management
is_live_pid() {
    _pid="$1"
    [ -n "$_pid" ] || return 1
    [ -d "/proc/$_pid" ] || return 1
    _state=$(awk '/^State:/ { print $2; exit }' "/proc/$_pid/status" 2>/dev/null)
    case "$_state" in
        Z) return 1 ;;
    esac
    return 0
}

list_live_pids() {
    for _pid in $(pgrep -x "$PROCESS_NAME" 2>/dev/null); do
        if is_live_pid "$_pid"; then
            echo "$_pid"
        fi
    done
}

get_first_pid() {
    for _pid in $(list_live_pids); do
        echo "$_pid"
        return 0
    done
    return 1
}

get_pid_count() {
    _count=0
    for _pid in $(list_live_pids); do
        _count=$((_count + 1))
    done
    echo "$_count"
}

is_running() {
    [ -n "$(get_first_pid)" ]
}

# Version
get_version() {
    if [ -f "$MODDIR/module.prop" ]; then
        grep '^version=' "$MODDIR/module.prop" | cut -d= -f2 | tr -d '\r\n'
    fi
}

# Profiles
get_active_profile() {
    if [ -f "$ACTIVE_PROFILE_FILE" ]; then
        _pname=$(head -n 1 "$ACTIVE_PROFILE_FILE" 2>/dev/null | tr -d '\r\n')
        [ -n "$_pname" ] && {
            echo "$_pname"
            return
        }
    fi
    echo "$DEFAULT_PROFILE"
}

get_profile_config_file() {
    echo "$PROFILE_DIR/$1.conf"
}

get_active_profile_config() {
    get_profile_config_file "$(get_active_profile)"
}

profile_uses_user_list() {
    _pname="$1"
    _pconfig=$(get_profile_config_file "$_pname")
    [ -f "$_pconfig" ] || return 1
    grep -F -q -e "$USER_LIST_FILE" "$_pconfig" 2>/dev/null
}

active_profile_uses_user_list() {
    profile_uses_user_list "$(get_active_profile)"
}

profile_exists() {
    [ -f "$(get_profile_config_file "$1")" ]
}

get_profile_label() {
    _pname="$1"
    _plabel="$_pname"
    _pconfig=$(get_profile_config_file "$_pname")

    if [ -f "$_pconfig" ]; then
        _pline=$(grep -m 1 '^# profile:' "$_pconfig" 2>/dev/null)
        if [ -n "$_pline" ]; then
            _plabel=$(printf '%s' "$_pline" | sed 's/^# profile:[[:space:]]*//')
        fi
    fi

    echo "$_plabel"
}

set_active_profile() {
    _pname="$1"
    profile_exists "$_pname" || {
        echo "[-] Unknown profile: $_pname"
        exit 1
    }
    mkdir -p "$PROFILE_DIR" >/dev/null 2>&1
    printf '%s\n' "$_pname" > "$ACTIVE_PROFILE_FILE"
}

list_profiles() {
    _found=0
    for _pconfig in "$PROFILE_DIR"/*.conf; do
        [ -f "$_pconfig" ] || continue
        _pname=$(basename "$_pconfig" .conf)
        printf '%s\t%s\n' "$_pname" "$(get_profile_label "$_pname")"
        _found=1
    done
    [ "$_found" = "1" ] || echo "(no profiles found)"
}

# Counters with cache
get_list_count() {
    _cache_file="$1"
    _list_file="$2"
    _force="$3"

    # Return cached value unless forced refresh.
    if [ "$_force" != "1" ] && [ -f "$_cache_file" ]; then
        cat "$_cache_file"
        return
    fi

    if [ -f "$_list_file" ]; then
        _count=$(wc -l < "$_list_file" 2>/dev/null || echo 0)
    else
        _count=0
    fi

    echo "$_count" > "$_cache_file" 2>/dev/null
    echo "$_count"
}

refresh_counts() {
    get_list_count "$LIST_COUNT_CACHE" "$GENERAL_LIST_FILE" 1 >/dev/null
}

get_plain_list_count() {
    _list_file="$1"
    if [ -f "$_list_file" ]; then
        sed '/^[[:space:]]*#/d; /^[[:space:]]*$/d' "$_list_file" | wc -l | tr -d '[:space:]'
    else
        echo 0
    fi
}

get_user_list_count() {
    get_plain_list_count "$USER_LIST_FILE"
}

trim_list_entry() {
    printf '%s' "$1" | tr -d '\r' | sed 's/^[[:space:]]*//; s/[[:space:]]*$//'
}

make_temp_file() {
    _tmp=$(mktemp 2>/dev/null)
    if [ -z "$_tmp" ]; then
        _tmp="/data/local/tmp/nzapret.$$.tmp"
        : > "$_tmp" 2>/dev/null || return 1
    fi
    echo "$_tmp"
}

write_user_list_entries() {
    _tmp=$(make_temp_file) || return 1
    : > "$_tmp" || {
        rm -f "$_tmp"
        return 1
    }

    for _entry in "$@"; do
        _clean=$(trim_list_entry "$_entry")
        case "$_clean" in
            ""|\#*) continue ;;
        esac
        if grep -F -x -q -e "$_clean" "$_tmp" 2>/dev/null; then
            continue
        fi
        printf '%s\n' "$_clean" >> "$_tmp" || {
            rm -f "$_tmp"
            return 1
        }
    done

    mv -f "$_tmp" "$USER_LIST_FILE" || {
        rm -f "$_tmp"
        return 1
    }
}

append_user_list_entries() {
    _tmp=$(make_temp_file) || return 1
    : > "$_tmp" || {
        rm -f "$_tmp"
        return 1
    }

    if [ -f "$USER_LIST_FILE" ]; then
        while IFS= read -r _line || [ -n "$_line" ]; do
            printf '%s\n' "$_line" >> "$_tmp" || {
                rm -f "$_tmp"
                return 1
            }
        done < "$USER_LIST_FILE"
    fi

    _added=0
    for _entry in "$@"; do
        _clean=$(trim_list_entry "$_entry")
        case "$_clean" in
            ""|\#*) continue ;;
        esac
        if grep -F -x -q -e "$_clean" "$_tmp" 2>/dev/null; then
            continue
        fi
        printf '%s\n' "$_clean" >> "$_tmp" || {
            rm -f "$_tmp"
            return 1
        }
        _added=$((_added + 1))
    done

    mv -f "$_tmp" "$USER_LIST_FILE" || {
        rm -f "$_tmp"
        return 1
    }

    echo "$_added"
}

remove_user_list_entries() {
    _tmp=$(make_temp_file) || return 1
    : > "$_tmp" || {
        rm -f "$_tmp"
        return 1
    }

    while IFS= read -r _line || [ -n "$_line" ]; do
        _keep=1
        for _entry in "$@"; do
            _clean=$(trim_list_entry "$_entry")
            case "$_clean" in
                ""|\#*) continue ;;
            esac
            if [ "$_line" = "$_clean" ]; then
                _keep=0
                break
            fi
        done
        [ "$_keep" = "1" ] && printf '%s\n' "$_line" >> "$_tmp"
    done < "$USER_LIST_FILE"

    mv -f "$_tmp" "$USER_LIST_FILE" || {
        rm -f "$_tmp"
        return 1
    }
}

print_user_list_status() {
    _user_count=$(get_user_list_count)
    if active_profile_uses_user_list; then
        echo "list-user.txt: $_user_count domains (active in current profile)"
    else
        echo "list-user.txt: $_user_count domains (current profile does not reference it)"
    fi
    echo ""
    echo "Domains:"
    if [ "$_user_count" -gt 0 ]; then
        sed '/^[[:space:]]*#/d; /^[[:space:]]*$/d' "$USER_LIST_FILE"
    else
        echo "(empty)"
    fi
}

print_user_list_contents() {
    [ -f "$USER_LIST_FILE" ] || return 0
    cat "$USER_LIST_FILE"
}

# Status printers

print_profile_status() {
    _pname=$(get_active_profile)
    echo "Active profile: $_pname ($(get_profile_label "$_pname"))"
}

print_status_human() {
    _ver=$(get_version)
    _pid=$(get_first_pid)
    _pid_count=$(get_pid_count)
    _rules=$(get_rule_count iptables)
    _rules6=$(get_rule_count ip6tables)
    _lc=$(get_list_count "$LIST_COUNT_CACHE" "$GENERAL_LIST_FILE")
    _google_lc=$(get_plain_list_count "$GOOGLE_LIST_FILE")
    _user_lc=$(get_user_list_count)

    [ -n "$_ver" ] && echo "Module version: $_ver"

    if [ -n "$_pid" ]; then
        echo "nfqws2: [ON] (PID: $_pid)"
        [ "$_pid_count" -gt 1 ] && echo "warning: multiple nfqws2 processes detected ($_pid_count)"
    else
        echo "nfqws2: [OFF]"
    fi

    echo "iptables rules: $_rules (IPv4), $_rules6 (IPv6)"
    print_profile_status
    echo ""

    if [ -f "$GENERAL_LIST_FILE" ]; then
        echo "list-general.txt: $_lc domains"
    else
        echo "list-general.txt: MISSING"
    fi

    if [ -f "$GOOGLE_LIST_FILE" ]; then
        echo "list-google.txt: $_google_lc domains"
    else
        echo "list-google.txt: MISSING"
    fi

    echo "list-user.txt: $_user_lc domains"
    if active_profile_uses_user_list; then
        echo "list-user binding: active in current profile"
    else
        echo "list-user binding: inactive (profile missing --hostlist=$USER_LIST_FILE)"
    fi
}

print_status_json() {
    _pid=$(get_first_pid)
    _pid_count=$(get_pid_count)
    if [ -n "$_pid" ]; then
        _active=true
    else
        _active=false
    fi

    _ver=$(get_version)
    _rules=$(get_rule_count iptables)
    _rules6=$(get_rule_count ip6tables)
    _lc=$(get_list_count "$LIST_COUNT_CACHE" "$GENERAL_LIST_FILE")
    _google_lc=$(get_plain_list_count "$GOOGLE_LIST_FILE")
    _user_lc=$(get_user_list_count)
    _prof_name=$(get_active_profile)
    _prof_label=$(get_profile_label "$_prof_name")
    if active_profile_uses_user_list; then
        _user_attached=true
    else
        _user_attached=false
    fi

    printf '{"version":"%s","active":%s,"pid":"%s","pid_count":%s,"rules_v4":%s,"rules_v6":%s,"domain_count":%s,"google_domain_count":%s,"user_domain_count":%s,"user_list_attached":%s,"profile":"%s","profile_label":"%s"}\n' \
        "$(json_escape "$_ver")" "$_active" "$(json_escape "$_pid")" "$_pid_count" "$_rules" "$_rules6" "$_lc" "$_google_lc" "$_user_lc" "$_user_attached" "$(json_escape "$_prof_name")" "$(json_escape "$_prof_label")"
}

get_rule_count() {
    _tbl_cmd="$1"
    $_tbl_cmd -w -t mangle -L "$CHAIN" -n 2>/dev/null | grep -c NFQUEUE
}

check_jump_rule() {
    _tbl_cmd="$1"
    _hook="$2"
    $_tbl_cmd -w -t mangle -C "$_hook" -j "$CHAIN" >/dev/null 2>&1
}

has_jump_rules() {
    check_jump_rule iptables OUTPUT && return 0
    check_jump_rule iptables FORWARD && return 0
    check_jump_rule ip6tables OUTPUT && return 0
    check_jump_rule ip6tables FORWARD && return 0
    return 1
}

cleanup_jump_rules_local() {
    while check_jump_rule iptables OUTPUT; do
        iptables -w -t mangle -D OUTPUT -j "$CHAIN" >/dev/null 2>&1 || break
    done
    while check_jump_rule iptables FORWARD; do
        iptables -w -t mangle -D FORWARD -j "$CHAIN" >/dev/null 2>&1 || break
    done
    iptables -w -t mangle -F "$CHAIN" >/dev/null 2>&1
    iptables -w -t mangle -X "$CHAIN" >/dev/null 2>&1

    while check_jump_rule ip6tables OUTPUT; do
        ip6tables -w -t mangle -D OUTPUT -j "$CHAIN" >/dev/null 2>&1 || break
    done
    while check_jump_rule ip6tables FORWARD; do
        ip6tables -w -t mangle -D FORWARD -j "$CHAIN" >/dev/null 2>&1 || break
    done
    ip6tables -w -t mangle -F "$CHAIN" >/dev/null 2>&1
    ip6tables -w -t mangle -X "$CHAIN" >/dev/null 2>&1
}

wait_for_process_exit() {
    _tries="${1:-15}"
    while is_running && [ "$_tries" -gt 0 ]; do
        sleep 0.1 2>/dev/null || sleep 1
        _tries=$((_tries - 1))
    done
    ! is_running
}

run_uninstall_cleanup() {
    "$MODDIR/uninstall.sh" >/dev/null 2>&1 || true
}

# Service control
start_service() {
    "$MODDIR/service.sh" manual || return 1
    is_running
}

stop_service() {
    run_uninstall_cleanup

    if ! wait_for_process_exit 15; then
        killall -9 "$PROCESS_NAME" 2>/dev/null
        wait_for_process_exit 3 || return 1
    fi

    if has_jump_rules; then
        cleanup_jump_rules_local
        has_jump_rules && return 1
    fi

    return 0
}

# Safe download (uses tmp file + size check + HTTP error protection)
download_to_tmp() {
    _url="$1"
    _dest="$2"
    _label="$3"
    _tmp=$(mktemp 2>/dev/null || echo "/data/local/tmp/$(basename "$_dest").tmp")

    curl -s -f -L -o "$_tmp" "$_url" 2>/dev/null
    if [ -s "$_tmp" ]; then
        mv -f "$_tmp" "$_dest"
        echo "[+] $_label updated"
        return 0
    fi

    rm -f "$_tmp"
    echo "[-] Failed to download $_label"
    return 1
}

update_list_file() {
    if download_to_tmp "$DEFAULT_LIST_SOURCE" "$GENERAL_LIST_FILE" "list-general.txt"; then
        return 0
    fi
    return 1
}

list_required_runtime_files() {
    _active_profile_config=$(get_active_profile_config)
    printf '%s\n' \
        "$BIN" \
        "$_active_profile_config" \
        "$GENERAL_LIST_FILE" \
        "$USER_LIST_FILE" \
        "$GOOGLE_LIST_FILE" \
        "$LUA_DIR/zapret-lib.lua" \
        "$LUA_DIR/zapret-antidpi.lua" \
        "$PAYLOAD_QUIC_FILE" \
        "$PAYLOAD_TLS_FILE"
}

refresh_hostlists_if_running() {
    if is_running; then
        _reloaded=0
        for _pid in $(list_live_pids); do
            if kill -HUP "$_pid" 2>/dev/null; then
                _reloaded=1
            fi
        done
        if [ "$_reloaded" = "1" ]; then
            echo "[*] Sent SIGHUP to nfqws2 to refresh hostlists."
        else
            echo "[*] nfqws2 is running. Hostlists reload automatically after file changes."
        fi
        return 0
    fi
    echo "[*] nzapret is not running. Changes will apply on next start."
    return 0
}

# Diagnostics
run_diagnose() {
    echo "nzapret diagnostics"
    echo "--------------------"

    for _cmd in $DIAGNOSE_COMMANDS; do
        if has_cmd "$_cmd"; then
            print_human_check ok "command available: $_cmd"
        else
            print_human_check fail "missing command: $_cmd"
        fi
    done

    for _file in $(list_required_runtime_files); do
        if [ -f "$_file" ]; then
            print_human_check ok "file present: $_file"
        else
            print_human_check fail "missing file: $_file"
        fi
    done

    _pid=$(get_first_pid)
    if [ -n "$_pid" ]; then
        print_human_check ok "$PROCESS_NAME running (PID: $_pid)"
    else
        print_human_check fail "$PROCESS_NAME is not running"
    fi

    if active_profile_uses_user_list; then
        print_human_check ok "active profile includes list-user.txt"
    else
        print_human_check fail "active profile does not reference list-user.txt"
    fi

    for _hook in OUTPUT FORWARD; do
        if check_jump_rule iptables "$_hook"; then
            print_human_check ok "iptables $_hook jump present"
        else
            print_human_check fail "iptables $_hook jump missing"
        fi

        if check_jump_rule ip6tables "$_hook"; then
            print_human_check ok "ip6tables $_hook jump present"
        else
            print_human_check fail "ip6tables $_hook jump missing"
        fi
    done

    if has_cmd ip; then
        if ip route get 1.1.1.1 >/dev/null 2>&1; then
            print_human_check ok "IPv4 route lookup works"
        else
            print_human_check fail "IPv4 route lookup failed"
        fi

        if ip -6 addr show scope global 2>/dev/null | grep -q 'inet6 '; then
            if ip -6 route get 2606:4700:4700::1111 >/dev/null 2>&1; then
                print_human_check ok "IPv6 route lookup works"
            else
                print_human_check fail "IPv6 route lookup failed"
            fi
        else
            print_human_check ok "IPv6 not configured on active network"
        fi
    fi

    print_profile_status
}

run_diagnose_json() {
    _checks=""
    _ok=0
    _fail=0
    _sep=""

    for _cmd in $DIAGNOSE_COMMANDS; do
        if has_cmd "$_cmd"; then
            append_json_check "$_cmd" "ok" "command available"
        else
            append_json_check "$_cmd" "fail" "command missing"
        fi
    done

    for _file in $(list_required_runtime_files); do
        _fname=$(basename "$_file")
        if [ -f "$_file" ]; then
            append_json_check "$_fname" "ok" "file present"
        else
            append_json_check "$_fname" "fail" "file missing"
        fi
    done

    _pid=$(get_first_pid)
    if [ -n "$_pid" ]; then
        append_json_check "$PROCESS_NAME process" "ok" "running (pid: $_pid)"
    else
        append_json_check "$PROCESS_NAME process" "fail" "not running"
    fi

    if active_profile_uses_user_list; then
        append_json_check "list-user binding" "ok" "active profile includes list-user.txt"
    else
        append_json_check "list-user binding" "fail" "active profile does not reference list-user.txt"
    fi

    for _hook in OUTPUT FORWARD; do
        if check_jump_rule iptables "$_hook"; then
            append_json_check "iptables $_hook" "ok" "jump present"
        else
            append_json_check "iptables $_hook" "fail" "jump missing"
        fi
        if check_jump_rule ip6tables "$_hook"; then
            append_json_check "ip6tables $_hook" "ok" "jump present"
        else
            append_json_check "ip6tables $_hook" "fail" "jump missing"
        fi
    done

    if has_cmd ip; then
        if ip route get 1.1.1.1 >/dev/null 2>&1; then
            append_json_check "IPv4 routing" "ok" "route lookup works"
        else
            append_json_check "IPv4 routing" "fail" "route lookup failed"
        fi
        if ip -6 addr show scope global 2>/dev/null | grep -q 'inet6 '; then
            if ip -6 route get 2606:4700:4700::1111 >/dev/null 2>&1; then
                append_json_check "IPv6 routing" "ok" "route lookup works"
            else
                append_json_check "IPv6 routing" "fail" "route lookup failed"
            fi
        else
            append_json_check "IPv6 routing" "ok" "not configured"
        fi
    fi

    _total=$((_ok + _fail))
    printf '{"checks":[%s],"summary":{"ok":%d,"fail":%d,"total":%d}}\n' \
        "$_checks" "$_ok" "$_fail" "$_total"
}

print_events_text() {
    _tail="${1:-30}"
    if [ -f "$EVENTLOG" ]; then
        tail -n "$_tail" "$EVENTLOG"
    else
        echo "No events recorded yet."
    fi
}

print_events_json() {
    _tail="${1:-30}"
    [ -f "$EVENTLOG" ] || { echo '[]'; return; }
    tail -n "$_tail" "$EVENTLOG" 2>/dev/null | {
        printf '['
        _sep=""
        _found=0
        while read -r _date _clock _type _msg || [ -n "$_date$_clock$_type$_msg" ]; do
            [ -n "$_date$_clock$_type" ] || continue
            printf '%s{"time":"%s %s","type":"%s","message":"%s"}' \
                "$_sep" \
                "$_date" \
                "$_clock" \
                "$_type" \
                "$(json_escape "$_msg")"
            _sep=","
            _found=1
        done
        [ "$_found" = "1" ] || printf ''
        printf ']\n'
    }
}

# Entry point
ensure_runtime_layout

[ $# -eq 0 ] && {
    set -- help
}

case "$1" in
    "start")
        if is_running; then
            echo "[!] nfqws2 is already running. Use 'nzapret restart' instead."
            exit 1
        fi
        echo "[*] Starting nzapret..."
        if start_service; then
            _pid=$(get_first_pid)
            echo "[+] nfqws2 started successfully (PID: $_pid)"
        else
            echo "[-] Failed to start nfqws2. Check 'nzapret log' for details."
            exit 1
        fi
        ;;

    "stop")
        echo "[*] Stopping nzapret..."
        if stop_service; then
            echo "[+] Stopped"
        else
            if ! has_jump_rules; then
                echo "[+] Stopped"
            else
                echo "[-] Failed to stop cleanly. Check 'nzapret log' for details."
                exit 1
            fi
        fi
        ;;

    "restart")
        echo "[*] Restarting nzapret..."
        if ! stop_service; then
            echo "[-] Failed to stop current nfqws2 instance cleanly."
            exit 1
        fi
        if start_service; then
            _pid=$(get_first_pid)
            echo "[+] nfqws2 restarted successfully (PID: $_pid)"
        else
            echo "[-] Failed to restart nfqws2. Check 'nzapret log' for details."
            exit 1
        fi
        ;;

    "update")
        require_cmd curl
        case "$2" in
            ""|"all"|"list")
                echo "[*] Updating list-general.txt..."
                if update_list_file; then
                    _new_count=$(wc -l < "$GENERAL_LIST_FILE" 2>/dev/null || echo "?")
                    log_event UPDATE "list-general.txt updated ($_new_count domains)"
                    refresh_counts
                    refresh_hostlists_if_running
                else
                    log_event ERROR "list-general.txt update failed"
                    exit 1
                fi
                ;;
            *)
                echo "Usage: nzapret update [list]"
                exit 1
                ;;
        esac
        ;;

    "status")
        case "$2" in
            "--json") print_status_json ;;
            *)        print_status_human ;;
        esac
        ;;

    "log")
        _pid=$(get_first_pid)
        _pid_count=$(get_pid_count)
        if [ -n "$_pid" ] && [ -d "/proc/$_pid" ]; then
            echo "nfqws2 is running (PID: $_pid)"
            [ "$_pid_count" -gt 1 ] && echo "warning: multiple nfqws2 processes detected ($_pid_count)"
            echo "Cmdline:"
            cat /proc/$_pid/cmdline 2>/dev/null | tr '\0' ' '
            echo ""
            echo ""
            echo "Open files: $(ls /proc/$_pid/fd 2>/dev/null | wc -l)"
            echo "Memory: $(grep VmRSS /proc/$_pid/status 2>/dev/null)"
        else
            echo "nfqws2 is not running"
        fi

        echo ""
        echo "Last 50 lines of logs:"
        if [ -f "$LOGFILE" ]; then
            tail -n 50 "$LOGFILE"
        else
            echo "Log file not found."
        fi
        ;;

    "profile")
        case "$2" in
            ""|"status")
                print_profile_status
                ;;
            "list")
                list_profiles
                ;;
            "set")
                [ -n "$3" ] || {
                    echo "Usage: nzapret profile set <name>"
                    exit 1
                }
                set_active_profile "$3"
                log_event PROFILE "changed to $3 ($(get_profile_label "$3"))"
                echo "[+] Active profile set to: $3"
                echo "[*] Restart nzapret to apply changes"
                ;;
            *)
                echo "Usage: nzapret profile [status|list|set <name>]"
                exit 1
                ;;
        esac
        ;;

    "list-user")
        case "$2" in
            ""|"status")
                print_user_list_status
                ;;
            "show")
                print_user_list_contents
                ;;
            "add")
                shift 2
                [ "$#" -gt 0 ] || {
                    echo "Usage: nzapret list-user add <domain> [domain...]"
                    exit 1
                }
                _added=$(append_user_list_entries "$@") || {
                    echo "[-] Failed to update list-user.txt"
                    exit 1
                }
                if [ "$_added" -eq 0 ]; then
                    echo "[*] list-user.txt already contains those domains"
                    exit 0
                fi
                _user_count=$(get_user_list_count)
                log_event USERLIST "added $_added domains ($_user_count total)"
                echo "[+] Added $_added domains to list-user.txt ($_user_count total)"
                refresh_hostlists_if_running
                ;;
            "remove")
                shift 2
                [ "$#" -gt 0 ] || {
                    echo "Usage: nzapret list-user remove <domain> [domain...]"
                    exit 1
                }
                _before=$(get_user_list_count)
                remove_user_list_entries "$@" || {
                    echo "[-] Failed to update list-user.txt"
                    exit 1
                }
                _after=$(get_user_list_count)
                _removed=$((_before - _after))
                if [ "$_removed" -le 0 ]; then
                    echo "[*] No matching domains found in list-user.txt"
                    exit 0
                fi
                log_event USERLIST "removed $_removed domains ($_after total)"
                echo "[+] Removed $_removed domains from list-user.txt ($_after total)"
                refresh_hostlists_if_running
                ;;
            "replace")
                shift 2
                [ "$#" -gt 0 ] || {
                    echo "Usage: nzapret list-user replace <domain> [domain...]"
                    exit 1
                }
                write_user_list_entries "$@" || {
                    echo "[-] Failed to rewrite list-user.txt"
                    exit 1
                }
                _user_count=$(get_user_list_count)
                log_event USERLIST "replaced list-user.txt ($_user_count total)"
                echo "[+] Saved list-user.txt ($_user_count domains)"
                refresh_hostlists_if_running
                ;;
            "clear")
                _before=$(get_user_list_count)
                : > "$USER_LIST_FILE" || {
                    echo "[-] Failed to clear list-user.txt"
                    exit 1
                }
                if [ "$_before" -gt 0 ]; then
                    echo "[+] list-user.txt cleared"
                    log_event USERLIST "cleared list-user.txt"
                    refresh_hostlists_if_running
                else
                    echo "[*] list-user.txt is already empty"
                fi
                ;;
            *)
                echo "Usage: nzapret list-user [status|show|add <domain...>|remove <domain...>|replace <domain...>|clear]"
                exit 1
                ;;
        esac
        ;;

    "diagnose")
        case "$2" in
            "--json") run_diagnose_json ;;
            *)        run_diagnose ;;
        esac
        ;;

    "events")
        _evt_tail=30
        _evt_json=0
        _evt_clear=0
        shift
        for _arg in "$@"; do
            case "$_arg" in
                "clear"|"--clear") _evt_clear=1 ;;
                --json) _evt_json=1 ;;
                --tail=*) _evt_tail="${_arg#--tail=}" ;;
            esac
        done
        if [ "$_evt_clear" = "1" ]; then
            : > "$EVENTLOG" || {
                echo "[-] Failed to clear event log."
                exit 1
            }
            echo "[+] Event log cleared."
        elif [ "$_evt_json" = "1" ]; then
            print_events_json "$_evt_tail"
        else
            print_events_text "$_evt_tail"
        fi
        ;;

    "help"|"--help"|"-h"|*)
        echo "nzapret Management Utility (Magisk)"
        echo "Usage: nzapret <command> [options]"
        echo ""
        echo "Commands:"
        echo "  start                       - start traffic interception"
        echo "  stop                        - stop interception and clear rules"
        echo "  restart                     - restart nfqws2 and iptables rules"
        echo "  update [list]               - update routing hostlist"
        echo "  status                      - show nfqws2, iptables and list info"
        echo "  status --json               - machine-readable status for WebUI"
        echo "  log                         - show nfqws2 runtime log"
        echo "  events                      - show event history"
        echo "  events clear                - clear the whole event log file"
        echo "  events --json [--tail=N]    - event history as JSON"
        echo "  profile <subcommand>        - show, list or switch nfqws2 profiles"
        echo "  list-user <subcommand>      - manage the personal domain hostlist"
        echo "  diagnose                    - run Android-side diagnostics"
        echo "  diagnose --json             - diagnostics as JSON for WebUI"
        echo "  help                        - show this help message"
        echo ""
        echo "Profile commands: status, list, set <name>"
        echo "User list commands: status, show, add, remove, replace, clear"
        ;;
esac
